{
    "algorithm": "MAPPO",
    "experiment_name": "GRU",
    "env": {
        "field_size": 40,
        "num_agents": 2,
        "max_steps": 2000
    },
    "reward": {
        "type": "LocalAccuracyExploration3",
        "formula": "reward = new_cell * 0.2 - 0.01 + localAccuracy * 5.0, completion_bonus",
        "new_cell_weight": 1.5,
        "collision_weight": 0.0,
        "step_penalty": 0.01,
        "alignment_weight": 0.1,
        "completion_bonus": 0.0,
        "completion_threshold": 0.95,
        "accuracy_weight": 5.0
    },
    "training": {
        "num_episodes": 1000,
        "lr": 0.0001,
        "gamma": 0.99,
        "clip_eps": 0.1,
        "lam": 0.95,
        "epochs": 5,
        "mini_batch_size": 16
    }
}