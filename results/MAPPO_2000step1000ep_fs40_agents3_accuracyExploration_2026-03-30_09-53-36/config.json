{
    "algorithm": "MAPPO",
    "experiment_name": "2000step1000ep",
    "env": {
        "field_size": 40,
        "num_agents": 3,
        "max_steps": 2000
    },
    "reward": {
        "type": "accuracyExploration",
        "formula": "reward = new_cell * 1.0 - 0.01 + aligment * 0.2 + accuracy * 150.0 + belief * 0.5",
        "new_cell_weight": 0.5,
        "collision_weight": 0.0,
        "step_penalty": 0,
        "alignment_weight": 0.1,
        "completion_bonus": 0.0,
        "completion_threshold": 0.95,
        "belief_weight": 0.5,
        "accuracy_weight": 150.0
    },
    "training": {
        "num_episodes": 1000,
        "lr": 0.0001,
        "gamma": 0.99,
        "clip_eps": 0.2,
        "lam": 0.95,
        "epochs": 5,
        "mini_batch_size": 128
    }
}